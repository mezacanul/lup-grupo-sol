{
  "expo": {
    "name": "SOL Yucatán",
    "slug": "lup",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "com.vientos.lup",
    "android": {
      "package": "com.eduardomzcn.lup"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "extra": {
      "eas": {
        "projectId": "4d3749e8-ecf5-4bf9-924b-3bae0343e6bf"
      }
    },
    "splash": {
      "backgroundColor": "#FFFFFF",
      "image": "./assets/splash_logo.png",
      "resizeMode": "contain"
    },
    "icon": "./assets/splash_logo.png",
    "plugins": [
      "expo-font",
      "expo-router",
      "expo-web-browser",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 25,
            "targetSdkVersion": 36,
            "compileSdkVersion": 36,
            "buildToolsVersion": "36.0.0"
          }
        }
      ],
      "expo-video"
    ]
  }
}
